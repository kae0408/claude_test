{% comment %}
  Image Accordion Section
  -----------------------------------------------------------------
  使い方:
  1. このファイルを sections/image-accordion.liquid として保存
  2. assets/ に image-accordion.css と image-accordion.js を追加
  3. テーマエディタで「セクションを追加」→「Image Accordion」を選択
  4. ブロックを追加して、画像・見出し・説明文・リンクを設定
-----------------------------------------------------------------
{% endcomment %}

{{ 'image-accordion.css' | asset_url | stylesheet_tag }}

<section
  class="ia-section"
  data-image-accordion
  style="
    --ia-bg: {{ section.settings.bg_color }};
    --ia-ink: {{ section.settings.text_color }};
    --ia-accent: {{ section.settings.accent_color }};
  "
>
  {% if section.settings.eyebrow != blank
    or section.settings.heading != blank
    or section.settings.lead != blank
  %}
    <div class="ia-header">
      {% if section.settings.eyebrow != blank %}
        <span class="ia-eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="ia-title">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.lead != blank %}
        <p class="ia-lead">{{ section.settings.lead | escape }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ia-accordion" role="list">
    {% for block in section.blocks %}
      {% assign is_first = false %}
      {% if forloop.first %}
        {% assign is_first = true %}
      {% endif %}

      <button
        class="ia-item{% if is_first %} is-active{% endif %}"
        role="listitem"
        {{ block.shopify_attributes }}
      >
        <span
          class="ia-item__media"
          style="background-image:url('{{ block.settings.image | image_url: width: 1600 }}');"
        ></span>
        <span class="ia-item__scrim"></span>
        <span class="ia-item__body">
          <span class="ia-item__index">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</span>
          {% if block.settings.title != blank %}
            <span class="ia-item__title">{{ block.settings.title | escape }}</span>
          {% endif %}
          {% if block.settings.description != blank %}
            <span class="ia-item__desc">{{ block.settings.description | escape }}</span>
          {% endif %}
          {% if block.settings.link != blank and block.settings.link_label != blank %}
            <a href="{{ block.settings.link }}" class="ia-item__link">
              {{ block.settings.link_label | escape }} →
            </a>
          {% endif %}
        </span>
      </button>
    {% endfor %}
  </div>
</section>

<script src="{{ 'image-accordion.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Image Accordion",
  "tag": "section",
  "class": "shopify-section--image-accordion",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイキャッチ（小見出し）",
      "default": "Craftsmanship"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "選ぶ理由は、ひとつじゃない。"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "リード文",
      "default": "各項目をタップすると詳しい説明が表示されます。"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色",
      "default": "#F6F3EC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "テキスト色",
      "default": "#1E2422"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "アクセントカラー",
      "default": "#B5651D"
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "パネル",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "説明文"
        },
        {
          "type": "url",
          "id": "link",
          "label": "リンク先"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "リンクテキスト",
          "default": "詳しく見る"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Accordion",
      "blocks": [
        { "type": "panel" },
        { "type": "panel" },
        { "type": "panel" },
        { "type": "panel" }
      ]
    }
  ]
}
{% endschema %}
